@inherits LayoutComponentBase

<MudThemeProvider Theme="_customTheme" IsDarkMode="false"/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <FlowAppBar/>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _customTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#ee1164",
            TextPrimary = "#ffffff",
        }
    };
}