@inherits LayoutComponentBase

<MudThemeProvider Theme="_customTheme"/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <FlowAppBar/>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {

    private MudTheme _customTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Secondary = "#ee1164"
        },
        PaletteDark = new PaletteDark() { 
            Primary = "#ee1164" 
        }
    };
}