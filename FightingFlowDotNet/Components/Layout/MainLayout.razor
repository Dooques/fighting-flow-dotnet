@inherits LayoutComponentBase

<MudThemeProvider Theme="_customTheme"/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <FlowAppBar/>
    <MudMainContent>
        <MudPaper class="rounded-0" Style="background-color: black; color: white;">
            <MudContainer MaxWidth="MaxWidth.False">
                @Body
            </MudContainer>
        </MudPaper>
    </MudMainContent>
</MudLayout>

@code {

    private MudTheme _customTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Secondary = "#ee1164"
        },
        PaletteDark = new PaletteDark() { 
            Primary = "#ee1164" 
        }
    };
}