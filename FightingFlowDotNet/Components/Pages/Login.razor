@page "/login"
@using FightingFlowDotNet.Models
@inject Supabase.Client SupabaseClient
@inject NavigationManager Navigation
@inject IHttpClientFactory ClientFactory

@rendermode InteractiveServer

<h3>Sign In</h3>

<div class="auth-container">
    <div class="form-group">
        <label>Email</label>
        <input type="email" @bind="email" class="form-control" />
    </div>
    <div class="form-group mt-2">
        <label>Password</label>
        <input type="password" @bind="password" class="form-control" />
    </div>

    <button class="btn btn-primary mt-3" @onclick="SignInWithEmail">Login with Email</button>
    
    <hr />

    <button class="btn btn-danger" @onclick="SignInWithGoogle">
        <img src="google-icon.svg" width="20" class="me-2" /> Sign in with Google
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger mt-2">@errorMessage</p>
}

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task SignInWithEmail()
    {
        Console.WriteLine("Attempting to sign in with email");
        var client = ClientFactory.CreateClient("MyApi");
        var protectedData = await client.GetFromJsonAsync<User>("auth");

        Console.WriteLine("Client Created");
        Console.WriteLine(protectedData);
        try
        {
            Console.WriteLine("Calling supabase.Auth.SignIn");
            // Call Supabase auth using C#
            var session = await SupabaseClient.Auth.SignIn(email, password);
            Console.WriteLine($"Session Created: {session?.AccessToken ?? "invalid token"}");
            if (session != null)
            {
                Console.WriteLine("Session Created, navigating to home");
                Navigation.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Exception occured: {errorMessage}");
        }
    }

    private async Task SignInWithGoogle()
    {
        try
        {
            // Trigger the Google OAuth Redirect
            await SupabaseClient.Auth.SignIn(Supabase.Gotrue.Constants.Provider.Google, new Supabase.Gotrue.SignInOptions
            {
                RedirectTo = Navigation.ToAbsoluteUri("/dashboard").ToString()
            });
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}