@page "/ComboEditor/{Name}/{EditMode:bool}/{ComboId}"
@using FightingFlowDotNet.Components.Reusable
@using FightingFlowDotNet.Models
@using FightingFlowDotNet.Resources.TekkenData

<PageTitle>Combo Editor</PageTitle>

<ComboDisplayer Combo="Combo" ChosenFighter="@GetChosenFighter()"></ComboDisplayer>

@code {
    [Parameter] public string Name { get; set; } = "";

    [Parameter] public bool EditMode { get; set; } = false;

    [Parameter] public string ComboId { get; set; } = "";

    public readonly ComboDisplay Combo = new(new Combo());

    private Fighter GetChosenFighter()
    {
        return TekkenFighters.Fighters.First(f => f.Name == Name);
    }

}