@page "/ComboEditor/{Name}/{EditMode:bool}/{ComboId}"

@using FightingFlowDotNet.Clients
@using FightingFlowDotNet.Components.Reusable
@using FightingFlowDotNet.Components.Reusable.Editor
@using FightingFlowDotNet.Models
@using FightingFlowDotNet.Resources.TekkenData
@inject FirestoreGetter FirestoreGetter

<PageTitle>Combo Editor</PageTitle>

<Container  
    Flex="Flex.Column.AlignContent.Center"
    Gap="Gap.Is5">
    
    <Container
        Flex="Flex.Column.JustifyContent.Center.AlignContent.Center"
        Gap="Gap.Is5">
        <ComboDisplayNoButtons Combo="Combo" />
        
        <ComboEditorButtons  />
        
        <ComboMetaFields 
            ComboTitle="ComboTitle"
            ComboDamage="ComboDamage"
            ComboDifficulty="ComboDifficulty"/>
        <Divider/>
    </Container>
    <Container Class="d-flex flex-column justify-start">
        @foreach (var type in _moveTypes)
        {
            <MoveSelector Moves="_moveList" Type="@type" CharacterName="@(Name)"/>
        }
    </Container>
    
</Container>


@code {
    [Parameter] 
    public string Name { get; set; } = "";

    [Parameter] 
    public bool EditMode { get; set; }

    [Parameter] 
    public string ComboId { get; set; } = "";

    private string ComboTitle { get; set; } = "";
    private int ComboDamage { get; set; }
    private int ComboDifficulty { get; set; }

    private readonly List<Move> _moveList = TekkenMoves.Moves;
    private readonly List<string> _moveTypes =
    [
        "Misc",
        "Modifier",
        "Movement",
        "Input",
        "Character",
        "Stances",
        "Mechanics",
        "Stage"
        
    ];

    public ComboDisplay Combo { get; set; } = new(new Combo());

    protected override async Task OnInitializedAsync()
    {
        Combo = new ComboDisplay(await GetComboFromFb());
    }

    private Fighter GetChosenFighter()
    {
        return TekkenFighters.Fighters.First(f => f.Name == Name);
    }

    private async Task<Combo> GetComboFromFb()
    {
        return await FirestoreGetter.GetCombo(Name, ComboId);
    }
}