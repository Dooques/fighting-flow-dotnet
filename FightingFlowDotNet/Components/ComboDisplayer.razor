@using FightingFlowDotNet.Models
@using FightingFlowDotNet.Resources.TekkenData

<div class="d-flex flex-column pb-5">
    <h4>@Combo.Combo.Title</h4>

    <div class="d-flex flex-row flex-wrap gap-2 py-1">
        @foreach (var moveItem in Combo.Combo.Moves.Select(GetMove))
        {
            if (moveItem.Notation is "►" or "h/burst")
            {
                <p class="my-auto">@moveItem.Notation</p>
            }
            else
            {
                <img src="@GetMoveImage(moveItem.Name)"
                     alt="@moveItem.Name" height="50" width="50"/>
            }
        }
    </div>

    <div class="d-flex flex-row justify-content-between mt-2">
        <div class="d-flex flex-column">
            <p class="mb-0">Damage: @Combo.Combo.Damage</p>
            <p>Created By: @Combo.Combo.CreatedBy</p>
        </div>
        <div class="d-flex flex-row align-content-start gap-3">
            <NavLink href="@GetEditorEditModeUrl()">
                <button class="btn btn-secondary align-self-start">
                    Edit
                </button>
            </NavLink>
            <NavLink>
                <button class="btn btn-primary align-self-start">
                    Share 
                </button>
            </NavLink>
        </div>
        <div>
            <p>Ki: @Combo.Ki</p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ComboDisplay Combo { get; set; }
    
    [Parameter]
    public Fighter ChosenFighter { get; set; }
    
    private readonly List<Move> _moveList = TekkenMoves.Moves;
    
    private string GetEditorEditModeUrl()
    {
        return $"/ComboEditor/{ChosenFighter.Name}/true";
    }
    
    private string GetEditorCreateModeUrl()
    {
        return $"/ComboEditor/{ChosenFighter.Name}/false";
    }

    private Move GetMove(string note)
    {
        return _moveList.First(m => m.Notation == note);
    }
    
    private static string GetMoveImage(string name)
    {
        return $"./images/{name}.png";
    }
}