<MudPaper
    Class="d-flex flex-row justify-space-around align-center gap-5"
    Width="100%"
    Style="background: inherit">
    <MudTextField 
        Label="Title"
        Lines="1"
        Variant="Variant.Outlined"
        Placeholder="Write a description of your combo"
        FullWidth="true"
        @bind-Value="ComboTitle"></MudTextField>
        
    <MudTextField
        Label="Damage"
        Lines="1"
        Variant="Variant.Outlined"
        @bind-Value="ComboDamage"
        Placeholder="0"></MudTextField>
    <MudElement
        Class="d-flex flex-column">
        <MudText>Difficulty</MudText>
        <MudRating
            @bind-SelectedValue="ComboDifficulty"
            Size="Size.Large"></MudRating>
    </MudElement>
</MudPaper>
@code {
    [Parameter] public object ComboTitle { get; set; } = "";
    [Parameter] public object ComboDamage { get; set; } = "";
    [Parameter] public int ComboDifficulty { get; set; }

}