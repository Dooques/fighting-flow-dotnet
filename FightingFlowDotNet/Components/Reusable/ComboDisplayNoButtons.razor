@using System.Text.Json
@using FightingFlowDotNet.Models
@using FightingFlowDotNet.Resources
@using FightingFlowDotNet.Resources.TekkenData


@if (DisplayCombo?.Combo.Moves == null)
{
    <Text>Loading Moves...</Text>
}
else
{
    <Div Flex="Flex.Row.Wrap.AlignItems.Center"
         Gap="Gap.Is2">
        @if (DisplayCombo?.Combo.Moves == null || !DisplayCombo.Combo.Moves.Any())
        {
            <p>No Moves found...</p>
        }
        else
        {
            foreach (var convertedMove in DisplayCombo.Combo.Moves.Select(GetMove))
            {
                Console.WriteLine($"Move: {convertedMove?.Name}, {convertedMove?.Type}");
                var text = convertedMove?.Notation;
                switch (convertedMove?.Type)
                {
                    case "Break":
                        <Span TextColor="TextColor.Info">
                            @(text)
                        </Span>
                        break;

                    case "Mechanics Input" or "Mechanic" or "Character" or "Mishima" or "Common" or "Stage" or "Special":
                        <Button Border="Border.Is0"
                                Background="@GetMoveBackgroundColor(convertedMove.Type)"
                                TextColor="@GetMoveTextColor(convertedMove.Type)"
                                TextWeight="TextWeight.Bold">
                            @convertedMove.Name
                        </Button>
                        break;

                    default:
                        if (convertedMove != null)
                        {
                            <img src="@GetMoveImage(convertedMove.Name)"
                                 alt="@convertedMove.Name"
                                 height="50" width="50"/>
                        }
                        break;
                }
            }
        }
    </Div>
}

@code {
    [Parameter]
    public DisplayCombo? DisplayCombo { get; set; }
    
    private List<Move>? _moveList = [];

    protected override void OnParametersSet()
    {
        if (DisplayCombo == null) return;
        
        _moveList = DisplayCombo?.Combo.Game switch
        {
            "Tekken 8" => Tekken8.Moves,
            "Street Fighter 6" => StreetFighter6.Moves,
            "Mortal Kombat 1" => MortalKombat1.Moves,
            _ => []
        };
        
        _moveList.AddRange(CommonMoves.Moves);
    }

    private Move? GetMove(string note)
    { 
        if (_moveList == null || string.IsNullOrEmpty(note)) return null;
        try
        {
            return _moveList.FirstOrDefault(m => m.Notation == note);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            return null;
        }
    }
    
    private static Background GetMoveBackgroundColor(string? type) => type switch
    {
        "Character" or "Mishima" => 
            Background.Primary,         // Custom Primary (Pink/Magenta)
        "Mechanics Input" => 
            Background.Secondary,       // Custom Secondary (Purple)
        "Modifier" => Background.Light, // Custom Light (Off-White)
        "Break" => Background.Info,           // Custom Info/Link (Cyan)
        "Stage" => Background.Success,           // Custom Success (Neon Green)
        "Stances" => Background.Danger,         // Custom Danger (Orange)
        _ =>  Background.Dark                 // Custom Dark (Deep Black)
    };
    
    private static TextColor GetMoveTextColor(string? type) => type switch
    {
        "Modifier" => TextColor.Dark,        // Use dark text on off-white backgrounds
        "Stage" => TextColor.Dark,           // Use dark text on bright neon green
        "Break" => TextColor.Dark,           // Use dark text on bright neon cyan
        _ => TextColor.Light                  // Use white text for purple, pink, and orange
    };

   private static string GetMoveImage(string name)
   {
       return $"images/{name}.png";
   }
}