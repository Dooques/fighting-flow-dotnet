@using FightingFlowDotNet.Models

<Card Flex="Flex.Shrink.Is1.Grow.Is1"
      Background="Background.Transparent">
    <Anchor To="@(GetListViewerUrl())" TextDecoration="TextDecoration.None">
        <img
            src="./images/@(Fighter.ImageId).png"
            style="max-width: 200px; max-height: 100%; object-fit: contain" 
            alt="@(Fighter.Name)"/>
        <CardBody>
            <Text TextColor="TextColor.Light">
                @Fighter.Name
            </Text>
        </CardBody>
    </Anchor>
</Card>

@code {
    [Parameter]
    public Fighter Fighter { get; set; } = new();

    private string GetListViewerUrl()
    {
        return Fighter.Name;
    }
}