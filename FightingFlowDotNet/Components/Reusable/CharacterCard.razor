@using FightingFlowDotNet.Models

<MudCard
    Style="color: white; background: inherit; width: 100%; height: 100%;"
    Class="flex-shrink-1">
    <MudNavLink
        Href="@(GetListViewerUrl())">
        <img 
            src="./images/@(Fighter.ImageId).png"
            style="max-width: 200px; max-height: 100%; object-fit: contain" 
            alt="@(Fighter.Name)"/>
        <MudCardContent>
            <MudText Typo="Typo.h6" Style="color: white">
                @Fighter.Name
            </MudText>
        </MudCardContent>
    </MudNavLink>
</MudCard>

@code {
    [Parameter]
    public Fighter Fighter { get; set; } = new();
    
    private string GetListViewerUrl()
    {
        return $"CombosFor/" + Fighter.Name;
    }
}